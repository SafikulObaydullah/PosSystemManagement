@model List<Stock_DataAccess.ViewModel.InvoiceVM>
@{
    ViewData["Title"] = "Invoice List";
    Layout = "~/Views/Shared/PrivateLayout.cshtml";
}

<style>
    .ui-autocomplete {
        max-height: 200px;
        overflow-y: scroll;
        overflow-x: hidden;
    }
</style>

<script src="~/commonui/js/configuration/invoice.js?v=@DateTime.Now.ToString("yymmddHHmmss")"></script>

<div class="page-wrapper">
    <main id="main" class="main">
        <div class="page-header d-print-none headerPaddingRemove">
            <div class="container-xl">
                <div class="row g-2 align-items-center">
                    <div class="col">
                        <h2 class="page-title">Invoice Information</h2>
                    </div>
                    <div class="col-auto ms-auto d-print-none">
                        <div class="btn-list">
                            <a href="#" onclick="AddNew()" class="btn btn-primary d-none d-sm-inline-block">
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
                                Create New Invoice
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="page-body pageBodyPaddingRemove">
            <div class="container-xl">
                <div class="row mb-2">
                    <div class="col-md-4">
                        <input type="search" id="VehicleName" class="form-control" placeholder="Search invoices..." onkeyup="load()" />
                    </div>
                    <div class="col-md-8 text-end">
                        <strong>Total Invoices:</strong> @Model.Count
                    </div>
                </div>

                <table class="table table-bordered" id="tble">
                    <thead>
                        <tr>
                            <td>InvoiceId</td>
                            <td>BanlanceDue</td>
                            <td>PaymentType</td>
                            <td>VehicleName</td>
                            <td>ChasisNo</td>
                            <td>EngineNo</td>
                            <td>FuelType</td>
                            <td>Color</td>
                            <td>ModelNo</td>
                            <td>Mileage</td>
                            <td>Amount</td>
                            <td>Tax</td>
                            <td>Discount</td>
                            <td>TotalAmount</td>
                            <td>Edit</td>
                            <td>Delete</td>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model)
                        {
                            <tr>
                                <td>@invoice.InvoiceId</td>
                                <td>@invoice.BanlanceDue</td>
                                <td>@invoice.PaymentType</td>
                                <td>@invoice.VehicleName</td>
                                <td>@invoice.ChasisNo</td>
                                <td>@invoice.EngineNo</td>
                                <td>@invoice.FuelType</td>
                                <td>@invoice.Color</td>
                                <td>@invoice.ModelNo</td>
                                <td>@invoice.Mileage</td>
                                <td>@invoice.Amount</td>
                                <td>@invoice.Tax</td>
                                <td>@invoice.Discount</td>
                                <td>@invoice.TotalAmount</td>
                                <td><button type="button" class="btn btn-sm btn-primary" onclick="Edit(@invoice.Id)">Edit</button></td>
                                <td><button type="button" class="btn btn-sm btn-danger" onclick="Delete(@invoice.Id)">Delete</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="modal fade" id="modalToggle" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="staticBackdropLabel">Create New Invoice</h5>
                        <span id="spanParentID" style="display:none">0</span>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row" style="justify-content: left;">
                            <div class="col-md-6">
                                <label class="form-label required">InvoiceId</label>
                                <input id="txtInvoiceId" class="form-control comboBox" style="width:100%; height:37px" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label required">BanlanceDue</label>
                                <input id="txtBanlanceDue" class="form-control" style="width:100%" required />
                            </div>
                        </div>
                        <div class="row g-3 mt-0" style="justify-content: left;">
                            <div class="col-md-6">
                                <label class="form-label required">PaymentType</label>
                                <input id="txtPaymentType" class="form-control comboBox" style="width:100%; height:37px" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label required">VehicleName</label>
                                <input type="hidden" id="txtVehicleName" />
                                <select class="form-control" id="ddlVehicleName" onchange="VehicleMethod(this)"></select>
                            </div>
                        </div>
                        <div class="row g-3 mt-0" style="justify-content: left;">
                            <div class="col-md-6">
                                <label class="form-label required">ChasisNo</label>
                                <input id="txtChasisNo" type="text" class="form-control comboBox" style="width:100%; height:37px" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label required">EngineNo</label>
                                <input id="txtEngineNo" type="text" class="form-control" style="width:100%" required />
                            </div>
                        </div>
                        <div class="row g-3 mt-0" style="justify-content: left;">
                            <div class="col-md-6">
                                <label class="form-label">FuelType</label>
                                <input type="text" id="txtFuelType" class="form-control comboBox" style="width:100%; height:37px" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Color</label>
                                <input type="text" id="txtColor" class="form-control comboBox" style="width:100%; height:37px" />
                            </div>
                        </div>
                        <div class="row g-3 mt-0" style="justify-content: left;">
                            <div class="col-md-6">
                                <label class="form-label">ModelNo</label>
                                <input type="text" id="txtModelNo" class="form-control comboBox" style="width:100%; height:37px" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Mileage</label>
                                <input type="number" id="txtMileage" class="form-control comboBox" style="width:100%; height:37px" />
                            </div>
                        </div>
                        <div class="row g-3 mt-0" style="justify-content: left;">
                            <div class="col-md-6">
                                <label class="form-label">Amount</label>
                                <input type="number" id="txtAmount" class="form-control comboBox" style="width:100%; height:37px" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tax</label>
                                <input type="number" id="txtTax" class="form-control comboBox" style="width:100%; height:37px" />
                            </div>
                        </div>
                        <div class="row g-3 mt-0" style="justify-content: left;">
                            <div class="col-md-6">
                                <label class="form-label">Discount</label>
                                <input type="number" id="txtDiscount" class="form-control comboBox" style="width:100%; height:37px" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">TotalAmount</label>
                                <input type="number" id="txtTotalAmount" class="form-control comboBox" style="width:100%; height:37px" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="btnClose" class="btn btn-secondary" onclick="Close()">Close</button>
                        <button type="button" id="btnSave" class="btn btn-ghost-primary active w-10" onclick="Save()">Save</button>
                        <button type="button" id="btnUpdate" class="btn btn-ghost-primary active w-10" onclick="Update()">Update</button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
