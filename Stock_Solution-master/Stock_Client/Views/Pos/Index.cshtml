@{
     Layout = "~/Views/Shared/PrivateLayout.cshtml";
    ViewData["Title"] = "POS - Point of Sale";
}

<h1>Point of Sale</h1>
<div class="page-wrapper">
    <div class="content">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                <h3>Product Search</h3>
                <input type="text" id="productSearch" class="form-control" placeholder="Scan barcode or enter product name" />
                <button id="addProduct" class="btn btn-primary mt-2">Add Product</button>
            </div>
            <div class="col-md-6">
                <h3>Cart</h3>
                <ul id="cart" class="list-group">
                    <!-- Cart items will be added here -->
                </ul>
                <div class="mt-3">
                    <strong>Total: $<span id="total">0.00</span></strong>
                </div>
                <button id="checkout" class="btn btn-success mt-2">Checkout</button>
            </div>
        </div>
    </div>
</div>
</div>


@section Scripts {
    <script>
        // Basic JavaScript for POS functionality
        let cart = [];
        let total = 0;

        document.getElementById('addProduct').addEventListener('click', function() {
            const product = document.getElementById('productSearch').value;
            if (product) {
                // Simulate adding product (replace with API call)
                const item = { name: product, price: 10.00 }; // Example
                cart.push(item);
                total += item.price;
                updateCart();
                document.getElementById('productSearch').value = '';
            }
        });

        document.getElementById('checkout').addEventListener('click', function() {
            if (cart.length > 0) {
                alert('Checkout successful! Total: $' + total.toFixed(2));
                cart = [];
                total = 0;
                updateCart();
            }
        });

        function updateCart() {
            const cartList = document.getElementById('cart');
            cartList.innerHTML = '';
            cart.forEach(item => {
                const li = document.createElement('li');
                li.className = 'list-group-item';
                li.textContent = `${item.name} - $${item.price.toFixed(2)}`;
                cartList.appendChild(li);
            });
            document.getElementById('total').textContent = total.toFixed(2);
        }
    </script>
}