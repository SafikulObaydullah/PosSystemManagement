<main id="main" class="main">
   @*<h2>Category Information</h2>
   <div class="float-r">
   <button style="font-size:20px;" title="Add Department" id="btnModal"
   data-toggle="modal" data-target="#MyModal">

   <h3>Create New Category</h3>
