@{
    ViewData["Title"] = "List of Movies";
    Layout = "~/Views/Shared/PrivateLayout.cshtml";
}
<script>
    $(document).ready(function () {
        $('#submitBtn').click(function () {
            // Gather form data
            var formData = {
                ParentCategoryId: $('#parentCategory').val(),
                CategoryName: $('#categoryName').val(),
                CategoryCode: $('#categoryCode').val(),
                Description: $('#description').val()
            };

            // Send AJAX request
            $.ajax({
                url: 'https://localhost:7065/api/Product/SaveSubCategory',
                type: 'POST',
                data: formData,
                success: function (response) {
                    if (response.result.IsSuccess) {
                        alert('Save Successful');
                    } else {
                        alert('Save Failed: ' + response.result.Message);
                    }
                },
                error: function (error) {
                    alert('Error: ' + error.responseText);
                }
            });
        });
    });
</script>
<div class="page-wrapper">
    <div class="content">
        <div class="page-header">
            <div class="page-title">
                <h4>Product Add Sub Category</h4>
                <h6>Create new product Category</h6>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Parent Category</label>
                            <select id="parentCategory" class="select">
                                <option value="">Choose Category</option>
                                <option value="1">Category 1</option>
                                <option value="2">Category 2</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Category Name</label>
                            <input type="text" id="categoryName">
                        </div>
                    </div>
                    <div class="col-lg-4 col-sm-6 col-12">
                        <div class="form-group">
                            <label>Category Code</label>
                            <input type="text" id="categoryCode">
                        </div>
                    </div>
                    <div class="col-lg-12">
                        <div class="form-group">
                            <label>Description</label>
                            <textarea id="description" class="form-control"></textarea>
                        </div>
                    </div>
                    <div class="col-lg-12">
                        <a href="javascript:void(0);" class="btn btn-submit me-2" id="submitBtn">Submit</a>
                        <a href="subcategorylist.html" class="btn btn-cancel">Cancel</a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>