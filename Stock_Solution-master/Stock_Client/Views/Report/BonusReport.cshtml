@{
   ViewData["Title"] = "Home Page";
   Layout = "~/Views/Shared/_LayoutAdmin.cshtml";


}

<script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
<script src="~/js/layoutjs/datefilterscript.js"></script>
<script src="~/js/setting/printthis.js"></script>
<script src="~/js/bonusreport.js"></script> 
<style>
   .multiselect-container {
      width: 100% !important;
   }

   .divworklogreport .form-check-input {
      margin-right: 5px;
   }

   .divworklogreport label {
      margin-bottom: 0px;
   }

   .divworklogreport .btn-group {
      margin-bottom: 10px;
   }

</style>
