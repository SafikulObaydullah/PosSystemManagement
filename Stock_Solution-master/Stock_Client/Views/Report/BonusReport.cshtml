@using System.Security.Claims;*@
<main id="main" class="main">
   <div class="new_order_container">
      <div class="header-container custom_header">
         <span class="custom_header_text">Bonus Report</span>
      </div>

      <div class="ls_top_bar">
         <div class="input-group" id="SearchOrder_custom">
            <input placeholder="Search by name" type="text" id="srch-emp-att" class="form-control col-lg-12">
            <div class="input-group-append">
               <div class="input-group-text" id="btn-search-emp-att"> <i class="fas fa-search"></i></div>
            </div>
         </div>
         <div class="input-group" id="SearchOrder_custom">
            <input placeholder="Search by Reg. No" type="text" id="srch-regno-att" class="form-control col-lg-12">
            <div class="input-group-append">
               <div class="input-group-text" id="btn-search-regno-att"> <i class="fas fa-search"></i></div>
            </div>
         </div>
         <div class="input-group" id="SearchOrder_custom">
            <input placeholder="Search by Designation" type="text" id="srch-designation-att" class="form-control col-lg-12">
            <div class="input-group-append">
               <div class="input-group-text" id="btn-search-designation-att"> <i class="fas fa-search"></i></div>
            </div>
         </div>
         <div class="input-group" id="SearchOrder_custom">
            <input placeholder="Search by Department" type="text" id="srch-department-att" class="form-control col-lg-12">
            <div class="input-group-append">
               <div class="input-group-text" id="btn-search-department-att"> <i class="fas fa-search"></i></div>
            </div>
         </div>
         <div class="date_range">
            <table class="cell_gap_table">
               <tr>
                  <td>
                     <input type="text" id="ReviewFilterStartDate" readonly class="form-control green_border_color filter_input_margin date-picker-dt" placeholder="Day" value="@DateTime.UtcNow.AddHours(6).ToString("dd-MM-yyyy")" />
                  </td>
               </tr>
            </table>
         </div>

         <div class="date_range">
            <table class="cell_gap_table">
               <tr>
                  <td>
                     <input type="text" id="BonusReviewFilterTodate" readonly class="form-control green_border_color filter_input_margin date-picker-dt" placeholder="To date" value="@DateTime.UtcNow.AddHours(6).ToString("dd-MM-yyyy")" />
                  </td>
               </tr>
            </table>
         </div>

         <input type="checkbox" id="selected1" name="selected" value="Blue" class="products"> Blue<br>
         <input type="checkbox" id="selected2" name="selected" value="Green" class="products"> Green<br>
         <input type="checkbox" id="selected3" name="selected" value="Purple" class="products"> Purple<br>

         <div>
            <input type="radio" name="Export" class="employeeCheckbox" data-employee-id="ExportAll">All<br>
            <input type="radio" name="Export" class="employeeCheckbox" data-employee-id="Filter">Filter <br>
            <input type="radio" name="Export" class="employeeCheckbox" data-employee-id="Selected">Selected<br>
         </div>


         <input type="radio" name="ExportData" data-employee-id="ExportAll" class="ExportCheckbox"> ExportAll<br>
         <input type="radio" name="ExportData" data-employee-id="ExportFilter" class="ExportCheckbox"> Export Filter Record<br>
         <input type="radio" name="ExportData" data-employee-id="ExportSelected" class="ExportCheckbox"> ExportSelectedRecord<br>

         <button type="button" class="btn btn-success" id="DownloadBonusReport"><i class="fas fa-download"></i></button>

         <a hidden class="btn btn-success" href="/reports/attendance-report">Monthly Attendance</a>
         <button class="btn btn-success" id="btn-apply-bonus-report-filter">Apply</button>
      </div>
   </div>
   <div id="tab-data">
      <div id="load-exc">
         <div class="grid-list-exc"></div>

         <div class="grid-list-exc-page"></div>
      </div>
   </div>
</main>


